// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  forms     Form[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Form {
  id          String      @id @default(cuid())
  title       String
  description String?
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  fields      FormField[]
  submissions Submission[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model FormField {
  id          String   @id @default(cuid())
  formId      String
  form        Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  label       String
  type        String   @default("text") // text, email, checkbox, etc.
  required    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Submission {
  id        String   @id @default(cuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  data      String   // JSON string of answers
  createdAt DateTime @default(now())
}
